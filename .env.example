# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development
AUTH_SECRET=replace-with-a-long-random-secret

# Database
DATABASE_URL=postgresql://apcc:apcc@localhost:5432/apcc_pilot?schema=public

# Google OAuth: create credentials in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/connectors/google/callback

# Optional fixed demo Google Sheets source.
GOOGLE_SHEETS_SPREADSHEET_ID=1dFXhXlD3g7NU8H7HjJJ2V3B4n3GrhUFfWoUpYeVWNzA
GOOGLE_SHEETS_DEFAULT_GID=1926972254

# Gmail / Calendar scopes are requested only after user consent.
GMAIL_SYNC_ENABLED=false
GOOGLE_CALENDAR_SYNC_ENABLED=false

# File storage
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads
