{
  "name": "apcc-pilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "postinstall": "prisma generate || true",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/smoke-test.mjs && node scripts/coproscan-tests.mjs",
    "test:coproscan": "node scripts/coproscan-tests.mjs",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "coproscan:purge-demo": "node -e \"require('./lib/coproscan/rgpd').purgeAllDemoData().then(console.log)\"",
    "coproscan:import-rnic": "node -e \"require('./lib/coproscan/rnic-importer').importAllTargetDepartments().then(r=>console.log(JSON.stringify(r,null,2)))\"",
    "deploy:up": "docker compose up --build -d",
    "deploy:migrate": "docker compose exec app npx prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "^15.0.0",
    "prisma": "^5.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.0",
    "typescript": "^5.7.2"
  }
}
